{
    "name": "visuellverstehen/statamic-content-renderer",
    "description": "A Statamic search transformer for bard and replicator fields.",
    "keywords": [ "statamic", "addon", "bard", "replicator", "search", "content", "fulltext" ],
    "license": "MIT",
    "type": "statamic-addon",
    "autoload": {
        "psr-4": {
            "VV\\ContentRenderer\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VV\\ContentRenderer\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "visuellverstehen"
        }
    ],
    "support": {
        "email": "hello@visuellverstehen.de"
    },
    "extra": {
        "statamic": {
            "name": "Content Renderer",
            "description": "A Statamic search transformer for bard and replicator fields."
        },
        "laravel": {
            "providers": [
                "VV\\ContentRenderer\\ServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "statamic/cms": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pixelfear/composer-dist-plugin": false
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
